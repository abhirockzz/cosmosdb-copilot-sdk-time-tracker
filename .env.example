# Required — your Cosmos DB account endpoint
COSMOS_ACCOUNT=https://your-account.documents.azure.com:443

# Optional (defaults shown)
COSMOS_DATABASE=timetracker
COSMOS_CONTAINER=timeEntries

# Emulator — set USE_EMULATOR=true to use the local Cosmos DB vNext emulator
# Start: docker run --detach --publish 8081:8081 --publish 1234:1234 mcr.microsoft.com/cosmosdb/linux/azure-cosmos-emulator:vnext-preview
# Data Explorer: http://localhost:1234
# USE_EMULATOR=true
# COSMOS_EMULATOR_ENDPOINT=http://localhost:8081   # optional, this is the default

# Copilot model — override the default model used by GitHub Copilot
# See supported models: https://docs.github.com/en/copilot/reference/ai-models/supported-models
# COPILOT_MODEL=gpt-4.1

# BYOK (Bring Your Own Key) — use your own model from Azure AI Foundry
# When set, the app uses your Azure OpenAI deployment instead of the default Copilot GPT-4.1.
# BYOK_AZURE_ENDPOINT=https://your-resource.openai.azure.com
# BYOK_AZURE_API_KEY=your-api-key
# BYOK_AZURE_MODEL=gpt-4o                  # your deployment name
# BYOK_AZURE_API_VERSION=2024-10-21        # optional, defaults to 2024-10-21

# BYOK Local — use a local model via Ollama, Foundry Local, or any OpenAI-compatible server
# When set, the app routes AI queries to your local model server.
# Performance depends on your hardware and model size. Use a model that supports tool/function calling.
#
# Ollama example:
#   BYOK_LOCAL_URL=http://localhost:11434/v1
#   BYOK_LOCAL_MODEL=qwen3
#
# Foundry Local example:
#   BYOK_LOCAL_URL=http://localhost:5272/v1
#   BYOK_LOCAL_MODEL=phi-4
#
# BYOK_LOCAL_URL=
# BYOK_LOCAL_MODEL=qwen3
# BYOK_LOCAL_API_KEY=                       # optional, not needed for Ollama
